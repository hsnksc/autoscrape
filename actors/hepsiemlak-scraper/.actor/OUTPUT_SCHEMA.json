{
    "actorOutputSchemaVersion": 1,
    "title": "Hepsiemlak İlan Verileri",
    "description": "Hepsiemlak.com'dan çekilen satılık/kiralık ilan bilgileri",
    "properties": {
        "url": {
            "title": "İlan URL",
            "type": "string",
            "description": "İlanın hepsiemlak.com üzerindeki tam URL adresi",
            "template": "<a href=\"{{{url}}}\">{{{url}}}</a>"
        },
        "listing_id": {
            "title": "İlan ID",
            "type": "string",
            "description": "Hepsiemlak iç ilan kimliği",
            "template": "{{{listing_id}}}"
        },
        "title": {
            "title": "İlan Başlığı",
            "type": "string",
            "description": "İlanın başlığı",
            "template": "{{{title}}}"
        },
        "category": {
            "title": "Kategori",
            "type": "string",
            "description": "İlan kategorisi (satilik veya kiralik)",
            "template": "{{{category}}}"
        },
        "property_type": {
            "title": "Mülk Türü",
            "type": "string",
            "description": "Mülk türü (konut, işyeri, arsa vb.)",
            "template": "{{{property_type}}}"
        },
        "seller_type": {
            "title": "Satıcı Türü",
            "type": "string",
            "description": "Satıcı tipi (sahibinden, emlakçıdan vb.)",
            "template": "{{{seller_type}}}"
        },
        "advertiser_type": {
            "title": "İlan Sahibi Tipi",
            "type": "string",
            "description": "İlan sahibinin tipi (bireysel, kurumsal vb.)",
            "template": "{{{advertiser_type}}}"
        },
        "advertiser_name": {
            "title": "İlan Sahibi Adı",
            "type": "string",
            "description": "İlanı yayınlayan kişi veya kurum adı",
            "template": "{{{advertiser_name}}}"
        },
        "city": {
            "title": "İl",
            "type": "string",
            "description": "Mülkün bulunduğu il",
            "template": "{{{city}}}"
        },
        "county": {
            "title": "İlçe",
            "type": "string",
            "description": "Mülkün bulunduğu ilçe",
            "template": "{{{county}}}"
        },
        "district": {
            "title": "Mahalle",
            "type": "string",
            "description": "Mülkün bulunduğu mahalle veya semt",
            "template": "{{{district}}}"
        },
        "price": {
            "title": "Fiyat",
            "type": "string",
            "description": "Mülkün satış veya kira fiyatı",
            "template": "{{{price}}}"
        },
        "currency": {
            "title": "Para Birimi",
            "type": "string",
            "description": "Fiyatın para birimi (TL, USD, EUR vb.)",
            "template": "{{{currency}}}"
        },
        "gross_sqm": {
            "title": "Brüt m²",
            "type": "string",
            "description": "Mülkün brüt metrekare alanı",
            "template": "{{{gross_sqm}}}"
        },
        "net_sqm": {
            "title": "Net m²",
            "type": "string",
            "description": "Mülkün net metrekare alanı",
            "template": "{{{net_sqm}}}"
        },
        "room_count": {
            "title": "Oda Sayısı",
            "type": "string",
            "description": "Oda sayısı (örn. 3+1)",
            "template": "{{{room_count}}}"
        },
        "bathroom_count": {
            "title": "Banyo Sayısı",
            "type": "string",
            "description": "Banyo sayısı",
            "template": "{{{bathroom_count}}}"
        },
        "floor": {
            "title": "Bulunduğu Kat",
            "type": "string",
            "description": "Mülkün bulunduğu kat",
            "template": "{{{floor}}}"
        },
        "floor_count": {
            "title": "Toplam Kat",
            "type": "string",
            "description": "Binadaki toplam kat sayısı",
            "template": "{{{floor_count}}}"
        },
        "building_age": {
            "title": "Bina Yaşı",
            "type": "string",
            "description": "Binanın yaşı veya yapım yılı",
            "template": "{{{building_age}}}"
        },
        "heating": {
            "title": "Isıtma",
            "type": "string",
            "description": "Isıtma sistemi türü",
            "template": "{{{heating}}}"
        },
        "credit_status": {
            "title": "Kredi Durumu",
            "type": "string",
            "description": "Krediye uygunluk durumu",
            "template": "{{{credit_status}}}"
        },
        "deed_status": {
            "title": "Tapu Durumu",
            "type": "string",
            "description": "Tapu türü (kat mülkiyeti, kat irtifakı vb.)",
            "template": "{{{deed_status}}}"
        },
        "furnished": {
            "title": "Eşyalı mı",
            "type": "string",
            "description": "Eşyalı/eşyasız durumu",
            "template": "{{{furnished}}}"
        },
        "usage_status": {
            "title": "Kullanım Durumu",
            "type": "string",
            "description": "Mülkün kullanım durumu (boş, kiracılı vb.)",
            "template": "{{{usage_status}}}"
        },
        "trade_status": {
            "title": "Takas",
            "type": "string",
            "description": "Takas olup olmadığı",
            "template": "{{{trade_status}}}"
        },
        "image_count": {
            "title": "Fotoğraf Sayısı",
            "type": "string",
            "description": "İlandaki fotoğraf sayısı",
            "template": "{{{image_count}}}"
        },
        "has_video": {
            "title": "Video Var mı",
            "type": "string",
            "description": "İlanda video bulunup bulunmadığı",
            "template": "{{{has_video}}}"
        },
        "latitude": {
            "title": "Enlem",
            "type": "string",
            "description": "Mülkün GPS enlem koordinatı",
            "template": "{{{latitude}}}"
        },
        "longitude": {
            "title": "Boylam",
            "type": "string",
            "description": "Mülkün GPS boylam koordinatı",
            "template": "{{{longitude}}}"
        },
        "description": {
            "title": "Açıklama",
            "type": "string",
            "description": "İlan açıklama metni",
            "template": "{{{description}}}"
        },
        "in_attributes": {
            "title": "İç Özellikler",
            "type": "string",
            "description": "İç mekan özellikleri (müstakil giriş, ebeveyn banyosu vb.)",
            "template": "{{{in_attributes}}}"
        },
        "location_attributes": {
            "title": "Konum Özellikleri",
            "type": "string",
            "description": "Konuma ait özellikler (deniz manzarası, metro yakını vb.)",
            "template": "{{{location_attributes}}}"
        },
        "room_attributes": {
            "title": "Oda Özellikleri",
            "type": "string",
            "description": "Odalara ait özellikler",
            "template": "{{{room_attributes}}}"
        },
        "service_attributes": {
            "title": "Hizmet Özellikleri",
            "type": "string",
            "description": "Hizmetler (güvenlik, kapıcı vb.)",
            "template": "{{{service_attributes}}}"
        },
        "usage_attributes": {
            "title": "Kullanım Özellikleri",
            "type": "string",
            "description": "Kullanım özellikleri (site içinde, bağımsız vb.)",
            "template": "{{{usage_attributes}}}"
        },
        "created_at": {
            "title": "Oluşturulma Tarihi",
            "type": "string",
            "description": "İlanın sisteme ilk eklenme tarihi",
            "template": "{{{created_at}}}"
        },
        "updated_at": {
            "title": "Güncellenme Tarihi",
            "type": "string",
            "description": "İlanın son güncellenme tarihi",
            "template": "{{{updated_at}}}"
        },
        "listing_updated_at": {
            "title": "İlan Güncelleme Tarihi",
            "type": "string",
            "description": "İlan sahibinin en son güncellediği tarih",
            "template": "{{{listing_updated_at}}}"
        },
        "scraped_at_utc": {
            "title": "Çekilme Zamanı (UTC)",
            "type": "string",
            "description": "Verinin çekildiği UTC zaman damgası (ISO 8601)",
            "template": "{{{scraped_at_utc}}}"
        }
    }
}
