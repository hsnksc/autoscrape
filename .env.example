# ── Orchestrator ──
PORT=3001
LOG_LEVEL=info

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Exa AI ──
# API key: https://exa.ai → Dashboard → API Keys
EXA_API_KEY=your_exa_api_key_here

# Emlak sitelerine filtreleme (opsiyonel)
EXA_INCLUDE_DOMAINS=sahibinden.com,hepsiemlak.com,emlakjet.com,zingat.com,hurriyetemlak.com

# Bir çağrıda max sonuç sayısı (1-50)
EXA_NUM_RESULTS=50

# ── Google Maps ──
# API key: https://console.cloud.google.com → Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Apify ──
# Token: https://console.apify.com → Settings → Integrations → API Token
APIFY_TOKEN=your_apify_token_here

# Apify aktör ID
APIFY_ACTOR_ID=olivine_lemur~unified-real-estate-scraper

# Eş zamanlı scrape worker sayısı (varsayılan: 3)
APIFY_CONCURRENCY=3

# Worker başlangıçları arası gecikme sn (varsayılan: 1.5)
APIFY_DELAY=1.5

# ── AutoScrape Webhook ──
# Apify aktörünüń tamamlanınca POST atacagı URL
# Production'da public domain olmalı; local test için ngrok kullan
WEBHOOK_URL=http://localhost:3001/api/webhook/apify

# ── Sahibinden ──
# Sahibinden Cloudflare bypass için çerezler (JSON string, opsiyonel)
# Format: '[{"name":"__cf_bm","value":"...","domain":".sahibinden.com"}]'
SAHIBINDEN_COOKIES=
